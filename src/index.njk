---
pagination:
  data: site.langs
  size: 1
  alias: lang
  addAllPagesToCollections: true
permalink: "{{ langmeta[lang].home }}"
layout: layouts/base.njk
eleventyComputed:
  altUrls:
    es: "/"
    en: "/en/"
---
{% set t = i18n[lang] %}

<section class="hero">
  <div class="container hero-inner">
    <p class="eyebrow">{{ t.hero.eyebrow }}</p>
    <h1 class="hero-title">{{ t.hero.title }}</h1>
    <p class="hero-sub">{{ t.hero.subtitle }}</p>
    <div class="hero-cta">
      <a class="btn btn-primary" href="#contact">{{ t.hero.ctaPrimary }}</a>
      <a class="btn btn-ghost" href="#work">{{ t.hero.ctaSecondary }}</a>
    </div>
  </div>
</section>

<section id="services" class="section">
  <div class="container">
    <header class="section-head">
      <h2>{{ t.services.title }}</h2>
      <p class="section-sub">{{ t.services.subtitle }}</p>
    </header>
    <div class="grid grid-3">
      {%- for item in t.services.items %}
      <article class="card service">
        <span class="service-num">0{{ loop.index }}</span>
        <h3>{{ item.name }}</h3>
        <p>{{ item.desc }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

<section id="work" class="section section-alt">
  <div class="container">
    <header class="section-head">
      <h2>{{ t.work.title }}</h2>
      <p class="section-sub">{{ t.work.subtitle }}</p>
    </header>
    <div class="grid grid-2">
      {%- for p in projects %}
      <article class="card project">
        <div class="project-top">
          <h3>{{ p.name }}</h3>
          <span class="project-year">{{ p.year }}</span>
        </div>
        <p class="project-cat">{{ p.category[lang] }}</p>
        <p class="project-summary">{{ p.summary[lang] }}</p>
        <div class="project-foot">
          <ul class="tags">
            {%- for tag in p.tags %}<li>{{ tag }}</li>{%- endfor %}
          </ul>
          <a class="link-arrow" href="{{ p.url }}" target="_blank" rel="noopener">
            {{ t.work.visit }} <span aria-hidden="true">↗</span>
          </a>
        </div>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

<section id="about" class="section">
  <div class="container about-grid">
    <div class="about-text">
      <h2>{{ t.about.title }}</h2>
      <p>{{ t.about.body }}</p>
    </div>
    <ul class="founders">
      {%- for f in t.about.founders %}
      <li class="founder">
        <span class="founder-name">{{ f.name }}</span>
        <span class="founder-role">{{ f.role }}</span>
      </li>
      {%- endfor %}
    </ul>
  </div>
</section>

<section id="contact" class="section section-contact">
  <div class="container contact-inner">
    <h2>{{ t.contact.title }}</h2>
    <p class="section-sub">{{ t.contact.subtitle }}</p>
    <div class="hero-cta">
      <a class="btn btn-primary" href="mailto:{{ site.email }}">{{ t.contact.cta }}</a>
      <a class="btn btn-ghost" href="https://wa.me/{{ site.whatsapp }}" target="_blank" rel="noopener">{{ t.contact.or }}</a>
    </div>
  </div>
</section>
