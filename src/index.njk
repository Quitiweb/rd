---
pagination:
  data: site.langs
  size: 1
  alias: lang
  addAllPagesToCollections: true
permalink: "{{ langmeta[lang].home }}"
layout: layouts/base.njk
eleventyComputed:
  altUrls:
    es: "/"
    en: "/en/"
---
{% import "partials/preview.njk" as comp %}
{% set t = i18n[lang] %}

{# ---------- DESKTOP ICONS ---------- #}
<ul class="icons">
  <li class="icon" data-win="win-readme" tabindex="0">
    <span class="icon-img"><svg viewBox="0 0 48 48" width="44" height="44" aria-hidden="true">
      <path d="M10 4h20l8 8v32H10z" fill="#fff" stroke="#000" stroke-width="2"/>
      <path d="M30 4v8h8" fill="#c0c0c0" stroke="#000" stroke-width="2"/>
      <path d="M15 20h18M15 26h18M15 32h12" stroke="#1084d0" stroke-width="2"/>
    </svg></span>
    <span class="icon-label">{{ t.os.icons.readme }}</span>
  </li>

  {%- for p in projects %}
  <li class="icon" data-win="win-{{ p.slug }}" tabindex="0">
    <span class="icon-img">{{ comp.sitePreview(p, lang) }}</span>
    <span class="icon-label">{{ p.name }}</span>
  </li>
  {%- endfor %}

  <li class="icon" data-win="win-services" tabindex="0">
    <span class="icon-img"><svg viewBox="0 0 48 48" width="44" height="44" aria-hidden="true">
      <path d="M24 6l3 5h6l-2 6 5 3-5 3 2 6h-6l-3 5-3-5h-6l2-6-5-3 5-3-2-6h6z" fill="#ffcf3f" stroke="#000" stroke-width="2" stroke-linejoin="round"/>
      <circle cx="24" cy="24" r="6" fill="#c0c0c0" stroke="#000" stroke-width="2"/>
    </svg></span>
    <span class="icon-label">{{ t.os.icons.services }}</span>
  </li>
  <li class="icon" data-win="win-about" tabindex="0">
    <span class="icon-img"><svg viewBox="0 0 48 48" width="44" height="44" aria-hidden="true">
      <circle cx="18" cy="17" r="7" fill="#ffcf3f" stroke="#000" stroke-width="2"/>
      <path d="M6 42c0-7 6-12 12-12s12 5 12 12z" fill="#1084d0" stroke="#000" stroke-width="2"/>
      <circle cx="32" cy="19" r="6" fill="#ff5a3c" stroke="#000" stroke-width="2"/>
      <path d="M26 42c0-6 4-11 10-11s10 5 10 11z" fill="#008080" stroke="#000" stroke-width="2"/>
    </svg></span>
    <span class="icon-label">{{ t.os.icons.about }}</span>
  </li>
  <li class="icon" data-win="win-contact" tabindex="0">
    <span class="icon-img"><svg viewBox="0 0 48 48" width="44" height="44" aria-hidden="true">
      <rect x="6" y="12" width="36" height="24" fill="#fff" stroke="#000" stroke-width="2"/>
      <path d="M6 12l18 14 18-14" fill="none" stroke="#ff5a3c" stroke-width="2"/>
    </svg></span>
    <span class="icon-label">{{ t.os.icons.contact }}</span>
  </li>

  <li class="icon" data-win="win-files" tabindex="0">
    <span class="icon-img"><svg viewBox="0 0 48 48" width="44" height="44" aria-hidden="true">
      <rect x="10" y="5" width="28" height="38" rx="2" fill="#ffcf3f" stroke="#000" stroke-width="2"/>
      <rect x="14" y="10" width="20" height="9" fill="#fff" stroke="#000" stroke-width="1.5"/>
      <rect x="14" y="22" width="20" height="9" fill="#fff" stroke="#000" stroke-width="1.5"/>
      <rect x="14" y="34" width="20" height="6" fill="#fff" stroke="#000" stroke-width="1.5"/>
      <rect x="21" y="13" width="6" height="3" fill="#000"/>
      <rect x="21" y="25" width="6" height="3" fill="#000"/>
    </svg></span>
    <span class="icon-label">{{ t.os.apps.files }}</span>
  </li>
  <li class="icon" data-win="win-calc" tabindex="0">
    <span class="icon-img"><svg viewBox="0 0 48 48" width="44" height="44" aria-hidden="true">
      <rect x="9" y="4" width="30" height="40" rx="2" fill="#c0c0c0" stroke="#000" stroke-width="2"/>
      <rect x="14" y="9" width="20" height="9" fill="#9fd3a0" stroke="#000" stroke-width="1.5"/>
      <g fill="#444"><rect x="14" y="22" width="4" height="4"/><rect x="22" y="22" width="4" height="4"/><rect x="30" y="22" width="4" height="4"/>
      <rect x="14" y="29" width="4" height="4"/><rect x="22" y="29" width="4" height="4"/><rect x="30" y="29" width="4" height="4"/>
      <rect x="14" y="36" width="4" height="4"/><rect x="22" y="36" width="4" height="4"/></g>
      <rect x="30" y="36" width="4" height="4" fill="#ff5a3c"/>
    </svg></span>
    <span class="icon-label">{{ t.os.apps.calc }}</span>
  </li>
  <li class="icon" data-win="win-mines" tabindex="0">
    <span class="icon-img"><svg viewBox="0 0 48 48" width="44" height="44" aria-hidden="true">
      <rect x="6" y="6" width="36" height="36" fill="#c0c0c0" stroke="#000" stroke-width="2"/>
      <g stroke="#000" stroke-width="3" stroke-linecap="round">
        <line x1="24" y1="11" x2="24" y2="37"/><line x1="11" y1="24" x2="37" y2="24"/>
        <line x1="15" y1="15" x2="33" y2="33"/><line x1="33" y1="15" x2="15" y2="33"/></g>
      <circle cx="24" cy="24" r="9" fill="#000"/><circle cx="21" cy="21" r="2.4" fill="#fff"/>
    </svg></span>
    <span class="icon-label">{{ t.os.apps.mines }}</span>
  </li>
</ul>

{# ---------- WINDOWS ---------- #}

<section class="window window-readme" id="win-readme" hidden>
  <div class="title-bar title-bar-active" data-drag>
    <span class="title-bar-text">{{ t.os.windows.readme }}</span>
    <div class="title-bar-controls"><button class="tb-btn" data-close aria-label="{{ t.os.close }}">✕</button></div>
  </div>
  <div class="window-body">
    <p class="eyebrow">★ {{ t.hero.eyebrow }} ★</p>
    <h1 class="readme-title">{{ t.hero.title }}</h1>
    <p>{{ t.hero.subtitle }}</p>
    <div class="btn-row">
      <button class="btn95" data-win="win-contact">{{ t.hero.ctaPrimary }}</button>
      <button class="btn95" data-close>{{ t.hero.ctaSecondary }}</button>
    </div>
    <p class="hint" data-openhint>↑ {{ t.os.openHint }}</p>
  </div>
</section>

<section class="window window-services" id="win-services" hidden>
  <div class="title-bar title-bar-active" data-drag>
    <span class="title-bar-text">{{ t.os.windows.services }}</span>
    <div class="title-bar-controls"><button class="tb-btn" data-close aria-label="{{ t.os.close }}">✕</button></div>
  </div>
  <div class="window-body">
    <h2>{{ t.services.title }}</h2>
    <p class="muted">{{ t.services.subtitle }}</p>
    <ul class="svc-list">
      {%- for item in t.services.items %}
      <li>
        <span class="svc-num">{{ loop.index }}.</span>
        <div>
          <strong>{{ item.name }}</strong>
          <p>{{ item.desc }}</p>
        </div>
      </li>
      {%- endfor %}
    </ul>
  </div>
</section>

{%- for p in projects %}
<section class="window window-project" id="win-{{ p.slug }}" hidden style="--accent: {{ p.accent }}">
  <div class="title-bar title-bar-active" data-drag>
    <span class="title-bar-text">{{ p.name }}</span>
    <div class="title-bar-controls"><button class="tb-btn" data-close aria-label="{{ t.os.close }}">✕</button></div>
  </div>
  <div class="window-body">
    <div class="proj-preview">{{ comp.sitePreview(p, lang) }}</div>
    <p class="project-cat">{{ p.category[lang] }} · {{ p.year }}</p>
    <p>{{ p.summary[lang] }}</p>
    <ul class="tags">
      {%- for tag in p.tags %}<li>{{ tag }}</li>{%- endfor %}
    </ul>
    <a class="btn95 btn95-go" href="{{ p.url }}" target="_blank" rel="noopener">{{ t.os.visit }} ↗</a>
  </div>
</section>
{%- endfor %}

<section class="window window-about" id="win-about" hidden>
  <div class="title-bar title-bar-active" data-drag>
    <span class="title-bar-text">{{ t.os.windows.about }}</span>
    <div class="title-bar-controls"><button class="tb-btn" data-close aria-label="{{ t.os.close }}">✕</button></div>
  </div>
  <div class="window-body">
    <h2>{{ t.about.title }}</h2>
    <p>{{ t.about.body }}</p>
    <ul class="founders">
      {%- for f in t.about.founders %}
      <li class="founder">
        <span class="founder-av">
          {%- if f.photo %}<img src="{{ f.photo | url }}" alt="{{ f.name }}" width="44" height="44" loading="lazy">
          {%- else %}{{ f.name | truncate(1, true, "") }}{% endif %}
        </span>
        <div>
          <strong>{{ f.name }}</strong>
          <span class="muted">{{ f.role }}</span>
        </div>
      </li>
      {%- endfor %}
    </ul>
  </div>
</section>

<section class="window window-contact" id="win-contact" hidden>
  <div class="title-bar title-bar-active" data-drag>
    <span class="title-bar-text">{{ t.os.windows.contact }}</span>
    <div class="title-bar-controls"><button class="tb-btn" data-close aria-label="{{ t.os.close }}">✕</button></div>
  </div>
  <div class="window-body">
    <h2>{{ t.contact.title }}</h2>
    <p class="muted">{{ t.contact.subtitle }}</p>
    <div class="btn-row">
      <a class="btn95" href="mailto:{{ site.email }}">✉ {{ t.contact.cta }}</a>
      <a class="btn95" href="https://wa.me/{{ site.whatsapp }}" target="_blank" rel="noopener">{{ t.contact.or }}</a>
    </div>
    <p class="hint muted">{{ site.email }}</p>
  </div>
</section>

{# ---------- EASTER EGGS: apps retro funcionales ---------- #}

<section class="window window-files" id="win-files" data-app hidden>
  <div class="title-bar title-bar-active" data-drag>
    <span class="title-bar-text">{{ t.os.apps.files }} — C:\</span>
    <div class="title-bar-controls"><button class="tb-btn" data-close aria-label="{{ t.os.close }}">✕</button></div>
  </div>
  <div class="window-body">
    <div class="files-path">{{ t.os.apps.filesPath }}</div>
    <div class="files-list">
      {%- for p in projects %}
      <button class="file-item" data-win="win-{{ p.slug }}">
        <span class="file-ico"></span>
        <span class="file-name">{{ p.slug | upper | replace("-", "") | truncate(8, true, "") }}.HTM</span>
      </button>
      {%- endfor %}
      <button class="file-item" data-win="win-services"><span class="file-ico"></span><span class="file-name">SERVICIO.TXT</span></button>
      <button class="file-item" data-win="win-about"><span class="file-ico"></span><span class="file-name">NOSOTROS.TXT</span></button>
      <button class="file-item" data-win="win-contact"><span class="file-ico"></span><span class="file-name">CONTACTO.TXT</span></button>
      <button class="file-item" data-win="win-readme"><span class="file-ico"></span><span class="file-name">LEEME.TXT</span></button>
      <button class="file-item" data-win="win-calc"><span class="file-ico file-ico-exe"></span><span class="file-name">CALC.EXE</span></button>
      <button class="file-item" data-win="win-mines"><span class="file-ico file-ico-exe"></span><span class="file-name">MINAS.EXE</span></button>
    </div>
  </div>
</section>

<section class="window window-app window-calc" id="win-calc" data-app hidden>
  <div class="title-bar title-bar-active" data-drag>
    <span class="title-bar-text">{{ t.os.apps.calc }}</span>
    <div class="title-bar-controls"><button class="tb-btn" data-close aria-label="{{ t.os.close }}">✕</button></div>
  </div>
  <div class="window-body">
    <div class="calc">
      <div class="calc-display" data-calc-display>0</div>
      <div class="calc-keys">
        <button class="btn95 calc-key calc-fn" data-k="clear">C</button>
        <button class="btn95 calc-key calc-fn" data-k="sign">±</button>
        <button class="btn95 calc-key calc-fn" data-k="pct">%</button>
        <button class="btn95 calc-key calc-op" data-k="/">÷</button>
        <button class="btn95 calc-key" data-k="7">7</button>
        <button class="btn95 calc-key" data-k="8">8</button>
        <button class="btn95 calc-key" data-k="9">9</button>
        <button class="btn95 calc-key calc-op" data-k="*">×</button>
        <button class="btn95 calc-key" data-k="4">4</button>
        <button class="btn95 calc-key" data-k="5">5</button>
        <button class="btn95 calc-key" data-k="6">6</button>
        <button class="btn95 calc-key calc-op" data-k="-">−</button>
        <button class="btn95 calc-key" data-k="1">1</button>
        <button class="btn95 calc-key" data-k="2">2</button>
        <button class="btn95 calc-key" data-k="3">3</button>
        <button class="btn95 calc-key calc-op" data-k="+">+</button>
        <button class="btn95 calc-key calc-zero" data-k="0">0</button>
        <button class="btn95 calc-key" data-k=".">.</button>
        <button class="btn95 calc-key calc-eq" data-k="=">=</button>
      </div>
    </div>
  </div>
</section>

<section class="window window-app window-mines" id="win-mines" data-app hidden>
  <div class="title-bar title-bar-active" data-drag>
    <span class="title-bar-text">{{ t.os.apps.mines }}</span>
    <div class="title-bar-controls"><button class="tb-btn" data-close aria-label="{{ t.os.close }}">✕</button></div>
  </div>
  <div class="window-body">
    <div class="mines">
      <div class="mines-head">
        <span class="mines-lcd" data-mines-left>010</span>
        <button class="mines-face" data-mines-face aria-label="{{ t.os.apps.mines }}">🙂</button>
        <span class="mines-lcd" data-mines-timer>000</span>
      </div>
      <div class="mines-grid" data-mines-grid></div>
      <button class="btn95 mines-flag" data-mines-flag aria-pressed="false">🚩 {{ t.os.apps.flagMode }}: <span data-flag-state>OFF</span></button>
      <p class="hint muted mines-hint">{{ t.os.apps.minesHint }}</p>
    </div>
  </div>
</section>
